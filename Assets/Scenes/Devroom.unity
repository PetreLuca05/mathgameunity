  interactDistance: 3
  skipCutscene: 0
  camerasParent: {fileID: 313557545}
  typeSpeed: 0.05
  allDialogLines:
  - dialog: Ai nevoie de inca 5 bani
    speakerIndex: 2
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Sa mi sugi pula de cordit infect
    speakerIndex: 1
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Da mi tigarea ca te tai smr!
    speakerIndex: 1
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Smr fam mea ce se intampla aici coaie
    speakerIndex: 0
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Nu ma inteleg cu asta nu vrea sa mi dea tigarea la bucata ca n am 5 bani
      ca cica am umplut carnetul de datorii
    speakerIndex: 1
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Daca mai gasesti tu 5 bani sa fac spume de nu cand ma chemi te ajut cu
      orice
    speakerIndex: 1
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  - dialog: Hai bine vad ce pot sa fac si te rezolv
    speakerIndex: 0
    delayForNextLine: 0
    isFlipped: 0
    dialogPanelOffset: {x: 0, y: 0}
  pointToTeleportPlayerTo: {fileID: 1989247325}
  delayBetweenLines: 1
